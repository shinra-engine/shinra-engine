{
  "name": "shinra-editor",
  "displayName": "Shinra Editor",
  "description": "Shinra engine editor viewport (MJPEG + WebSocket bridge)",
  "version": "0.2.0",
  "publisher": "shinra",
  "engines": { "vscode": "^1.74.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shinra.openGameViewport",
        "title": "Shinra Viewport: Gaming"
      },
      {
        "command": "shinra.openEditorViewport",
        "title": "Shinra Viewport: Editor"
      },
      {
        "command": "shinra.refreshScene",
        "title": "Shinra: Refresh Scene Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "shinra.saveScene",
        "title": "Shinra: Save Scene to File"
      },
      {
        "command": "shinra.loadScene",
        "title": "Shinra: Load Scene from File"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "shinraSceneTree",
          "name": "Shinra Scene"
        },
        {
          "id": "shinraInspector",
          "type": "webview",
          "name": "Shinra Inspector"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "shinra.refreshScene",
          "when": "view == shinraSceneTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc --watch -p ./",
    "package": "vsce package --no-dependencies",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0",
    "@playwright/test": "^1.40.0"
  }
}
